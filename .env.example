# ============================================================================
#  Taxzilla — Environment configuration
#  Copy this file to `.env.local` and fill in real values.
#  NEVER commit `.env.local` or any file containing real secrets.
# ============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the site (used for absolute links / redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# ── Supabase (Settings → API in your Supabase dashboard) ─────────────────────
# Run supabase/schema.sql once to create the tables + storage bucket.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# service_role secret — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_UPLOAD_BUCKET=uploads

# ── Session / Auth ──────────────────────────────────────────────────────────
# 32+ byte random secret used to sign admin session JWTs.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SESSION_SECRET=replace-with-a-long-random-secret-min-32-chars

# Admin login. Store ONLY a bcrypt hash of the password — never the plaintext.
# Generate a hash with:  node scripts/hash-password.mjs "YourStrongPassword"
# IMPORTANT: bcrypt hashes contain "$" which Next.js treats as a variable.
# Escape every "$" as "\$"  e.g.  \$2a\$12\$abc...   (otherwise login fails).
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash-escaping-dollar-signs

# Session lifetime in seconds (default 8h)
AUTH_SESSION_TTL=28800

# ── Email / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@taxzilla.in
SMTP_PASSWORD=replace-with-smtp-password

MAIL_FROM=
MAIL_CONTACT_RECIPIENT=
MAIL_NEWSLETTER_RECIPIENT=
MAIL_CAREERS_RECIPIENT=

# Set to "true" to print emails to the console instead of sending (local dev).
MAIL_DRY_RUN=true

# ── Uploads ─────────────────────────────────────────────────────────────────
# Max résumé/photo upload size in bytes (default 5 MB)
UPLOAD_MAX_BYTES=5242880

# ── Rate limiting ───────────────────────────────────────────────────────────
# Window (seconds) and max submissions per window per IP for public forms.
FORM_RATE_WINDOW=600
FORM_RATE_MAX=5
